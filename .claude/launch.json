{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cyclops-daemon",
      "runtimeExecutable": ".venv/Scripts/python",
      "runtimeArgs": ["-m", "cyclops_voice.cli", "daemon"],
      "port": 7788
    },
    {
      "name": "cyclops-api",
      "runtimeExecutable": ".venv/Scripts/python",
      "runtimeArgs": ["-m", "cyclops_voice.cli", "daemon", "--no-hotkey", "--no-tray"],
      "port": 7788
    }
  ,{
      "name": "web-preview",
      "runtimeExecutable": ".venv/Scripts/python",
      "runtimeArgs": ["-m", "http.server", "7791", "--directory", "src/cyclops_voice/web"],
      "port": 7791
    }
  ,{
      "name": "tuning-preview",
      "runtimeExecutable": ".venv/Scripts/python",
      "runtimeArgs": ["-m", "http.server", "7790", "--directory", "tuning/preview"],
      "port": 7790
    }
  ]
}
